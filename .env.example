# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Price IDs for the two plans. STRIPE_MONTHLY_PRICE_ID is the historical
# £300/20-leads price (also usable via STRIPE_PRICE_ID_20). STRIPE_PRICE_ID_10
# is the £150/10-leads price — create it in the Stripe dashboard.
STRIPE_MONTHLY_PRICE_ID=
STRIPE_PRICE_ID_20=
STRIPE_PRICE_ID_10=
# Guaranteed Rent monthly subscription price (£100/mo, 10 leads included).
STRIPE_GR_MONTHLY_PRICE_ID=

# --- Post-call discount offer (10% off first month, single-use, 24h) ---
# One-time Stripe setup (see README §"Post-call discount"):
#   1. Create ONE Coupon: percent_off=10, duration=once, currency=gbp,
#      name="Post-call 10%". Put its id here. The coupon may apply to both
#      Management products, but must NOT be a single-redemption coupon
#      (max_redemptions is set on each promotion CODE, not the coupon) and must
#      work on either Management Payment Link — one code, either link.
STRIPE_POST_CALL_COUPON_ID=
#   2. Enable "Allow promotion codes" on BOTH existing Management Payment Links
#      (Stripe dashboard, or payment_links.update(id,{allow_promotion_codes:true})).
#   3. Store both link base URLs here. The offer route appends
#      ?prefilled_promo_code=<code> to whichever the caller sends.
STRIPE_MANAGEMENT_10_PAYMENT_LINK_URL=https://buy.stripe.com/5kQdR8bzM6Ha5fh48P4Ja01
STRIPE_MANAGEMENT_20_PAYMENT_LINK_URL=https://buy.stripe.com/eVq14m8nA4z29vx20H4Ja00

# Monday.com
MONDAY_API_TOKEN=
MONDAY_LEAD_BOARD_ID=18420117742
# Guaranteed Rent leads board.
MONDAY_GR_LEAD_BOARD_ID=18396542480
# Optional: restrict GR sync to a single status label. Leave unset to send all
# GR leads (the default).
MONDAY_GR_SELLABLE_STATUS=
# Board the landing-page enquiry form writes contacts to.
MONDAY_ENQUIRY_BOARD_ID=18420649520

# n8n
N8N_WEBHOOK_SECRET=

# Contact verification (used by the 'invalid_contact' reject reason).
# Twilio Lookup v2 requires the Line Type Intelligence add-on enabled on the
# account. NOTE: Preview deployments make real, billable calls unless a separate
# set of test credentials is configured.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
ZEROBOUNCE_API_KEY=
# Outbound SMS sender for post-call offer reminders — a Twilio phone number in
# E.164 (e.g. +447700900123) or a Messaging Service SID. Reuses the account
# credentials above. If unset, reminder SMS are skipped and email still sends.
TWILIO_MESSAGING_FROM=

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=zac@stayful.co.uk

# App
NEXT_PUBLIC_APP_URL=
ADMIN_SECRET_KEY=

# Owner override: comma-separated emails that skip the Stripe payment wall at
# signup and are provisioned as active, admin-level accounts.
# Defaults to zac@stayful.co.uk when unset.
OWNER_EMAILS=zac@stayful.co.uk

# Secret bearer token the Monday sync cron uses to authorise itself. Vercel Cron
# automatically sends "Authorization: Bearer $CRON_SECRET" when this is set.
CRON_SECRET=
