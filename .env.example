# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Price IDs for the two plans. STRIPE_MONTHLY_PRICE_ID is the historical
# £300/20-leads price (also usable via STRIPE_PRICE_ID_20). STRIPE_PRICE_ID_10
# is the £150/10-leads price — create it in the Stripe dashboard.
STRIPE_MONTHLY_PRICE_ID=
STRIPE_PRICE_ID_20=
STRIPE_PRICE_ID_10=

# Monday.com
MONDAY_API_TOKEN=
MONDAY_LEAD_BOARD_ID=18420117742
# Board the landing-page enquiry form writes contacts to.
MONDAY_ENQUIRY_BOARD_ID=18420649520

# n8n
N8N_WEBHOOK_SECRET=

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=zac@stayful.co.uk

# App
NEXT_PUBLIC_APP_URL=
ADMIN_SECRET_KEY=

# Owner override: comma-separated emails that skip the Stripe payment wall at
# signup and are provisioned as active, admin-level accounts.
# Defaults to zac@stayful.co.uk when unset.
OWNER_EMAILS=zac@stayful.co.uk

# Secret bearer token the Monday sync cron uses to authorise itself. Vercel Cron
# automatically sends "Authorization: Bearer $CRON_SECRET" when this is set.
CRON_SECRET=
