{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "next build",
  "crons": [
    {
      "path": "/api/monday/sync",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/monday/sync-gr",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/generate-public-stats",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/inactivity-nudge",
      "schedule": "0 10 * * 1"
    },
    {
      "path": "/api/cron/progress-report",
      "schedule": "0 16 * * 5"
    }
  ]
}
